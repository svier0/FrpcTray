{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "frpc-tray",
  "version": "0.1.0",
  "identifier": "com.j7yx.svier0.frpc-tray",
  "build": {
    "beforeDevCommand": "cd frontend && bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cd frontend && bun run build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "frpc-tray",
        "width": 800,
        "height": 540
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": []
  }
}
