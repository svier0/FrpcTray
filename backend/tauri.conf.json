{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FrpcTray",
  "version": "2.0.0",
  "identifier": "com.j7yx.svier0.FrpcTray",
  "build": {
    "beforeDevCommand": "cd frontend && bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cd frontend && bun run build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": []
  }
}
