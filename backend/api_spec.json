{
  "version": "V3",
  "lastUpdated": "2026-06-27",
  "commands": [
    {
      "name": "list_servers",
      "description": "获取所有服务器配置列表（扫描 conf/frpc.*.toml）",
      "parameters": [],
      "returns": {
        "type": "Result<Vec<ServerInfo>, String>",
        "success": "按 sort 排序的服务器数组",
        "error": "错误信息字符串"
      }
    },
    {
      "name": "get_server",
      "description": "获取单个服务器配置",
      "parameters": [
        { "name": "id", "type": "String", "description": "服务器 ID（文件名中的标识）" }
      ],
      "returns": {
        "type": "Result<ServerInfo, String>",
        "success": "服务器配置对象",
        "error": "错误信息字符串"
      }
    },
    {
      "name": "create_server",
      "description": "创建新的服务器配置文件 conf/frpc.{id}.toml，id 由后端自动生成（单字母 a..z）",
      "parameters": [
        { "name": "input", "type": "CreateServerInput", "description": "服务器配置（不含 id）" }
      ],
      "returns": {
        "type": "Result<String, String>",
        "success": "自动生成的服务器 ID（单字母）",
        "error": "错误信息字符串"
      }
    },
    {
      "name": "update_server",
      "description": "更新服务器配置（保留 log/proxies）",
      "parameters": [
        { "name": "server", "type": "ServerInfo", "description": "新的服务器配置" }
      ],
      "returns": {
        "type": "Result<(), String>",
        "success": "空",
        "error": "错误信息字符串"
      }
    },
    {
      "name": "delete_server",
      "description": "删除服务器配置文件",
      "parameters": [
        { "name": "id", "type": "String", "description": "服务器 ID" }
      ],
      "returns": {
        "type": "Result<(), String>",
        "success": "空",
        "error": "错误信息字符串"
      }
    },
    {
      "name": "reorder_servers",
      "description": "批量更新服务器排序（按数组顺序分配 sort=1..N）",
      "parameters": [
        { "name": "ids", "type": "Vec<String>", "description": "排序后的服务器 ID 列表" }
      ],
      "returns": {
        "type": "Result<(), String>",
        "success": "空",
        "error": "错误信息字符串"
      }
    },
    {
      "name": "list_proxies",
      "description": "获取指定服务器的所有代理列表",
      "parameters": [
        { "name": "server_id", "type": "String", "description": "服务器 ID" }
      ],
      "returns": {
        "type": "Result<Vec<ProxyItem>, String>",
        "success": "代理配置数组",
        "error": "错误信息字符串"
      }
    },
    {
      "name": "create_proxy",
      "description": "在指定服务器中添加代理",
      "parameters": [
        { "name": "server_id", "type": "String", "description": "服务器 ID" },
        { "name": "proxy", "type": "ProxyItem", "description": "代理配置" }
      ],
      "returns": {
        "type": "Result<(), String>",
        "success": "空",
        "error": "错误信息字符串"
      }
    },
    {
      "name": "update_proxy",
      "description": "更新指定服务器中的代理（支持重命名，old_name 匹配原名）",
      "parameters": [
        { "name": "server_id", "type": "String", "description": "服务器 ID" },
        { "name": "old_name", "type": "String", "description": "代理原名" },
        { "name": "proxy", "type": "ProxyItem", "description": "新的代理配置" }
      ],
      "returns": {
        "type": "Result<(), String>",
        "success": "空",
        "error": "错误信息字符串"
      }
    },
    {
      "name": "delete_proxy",
      "description": "删除指定服务器中的代理",
      "parameters": [
        { "name": "server_id", "type": "String", "description": "服务器 ID" },
        { "name": "name", "type": "String", "description": "代理名称" }
      ],
      "returns": {
        "type": "Result<(), String>",
        "success": "空",
        "error": "错误信息字符串"
      }
    },
    {
      "name": "reorder_proxies",
      "description": "重新排序指定服务器中的代理（按数组顺序重排 [[proxies]]）",
      "parameters": [
        { "name": "server_id", "type": "String", "description": "服务器 ID" },
        { "name": "names", "type": "Vec<String>", "description": "排序后的代理名称列表" }
      ],
      "returns": {
        "type": "Result<(), String>",
        "success": "空",
        "error": "错误信息字符串"
      }
    },
    {
      "name": "get_frpc_version",
      "description": "获取 frpc 内核版本信息（当前版本/最新版本/可升级状态/平台/架构）",
      "parameters": [],
      "returns": {
        "type": "Result<FrpcVersionInfo, String>",
        "success": "版本信息对象",
        "error": "错误信息字符串"
      }
    },
    {
      "name": "upgrade_frpc",
      "description": "下载并升级/安装 frpc 内核（从 GitHub Releases 下载对应平台架构的 zip，解压并替换可执行文件）",
      "parameters": [
        { "name": "version", "type": "String", "description": "要下载的版本号，如 '0.69.1'（不含 v 前缀）" }
      ],
      "returns": {
        "type": "Result<(), String>",
        "success": "空（成功替换）",
        "error": "错误信息字符串（下载失败/解压失败/未找到 frpc 可执行文件/替换失败）"
      }
    }
  ],
  "dataStructures": {
    "ServerInfo": {
      "description": "服务器配置（对应 conf/frpc.{id}.toml）",
      "fields": [
        { "name": "id", "type": "String", "description": "服务器唯一标识（文件名中的 ID，如 frpc.w.toml → 'w'）" },
        { "name": "title", "type": "String", "description": "服务器标题" },
        { "name": "enable", "type": "bool", "description": "是否启用" },
        { "name": "sort", "type": "i32", "description": "排序序号" },
        { "name": "serverAddr", "type": "String", "description": "服务器地址（IP）" },
        { "name": "serverPort", "type": "u16", "description": "服务器端口" },
        { "name": "auth", "type": "AuthConfig | null", "description": "鉴权配置" },
        { "name": "transport", "type": "TransportConfig | null", "description": "传输配置（通信协议等）" },
        { "name": "tls", "type": "TlsConfig | null", "description": "TLS 配置" }
      ]
    },
    "CreateServerInput": {
      "description": "创建服务器时的输入（不含 id，由后端自动生成）",
      "fields": [
        { "name": "title", "type": "String", "description": "服务器标题" },
        { "name": "enable", "type": "bool", "description": "是否启用" },
        { "name": "sort", "type": "i32", "description": "排序序号" },
        { "name": "serverAddr", "type": "String", "description": "服务器地址（IP）" },
        { "name": "serverPort", "type": "u16", "description": "服务器端口" },
        { "name": "auth", "type": "AuthConfig | null", "description": "鉴权配置" },
        { "name": "transport", "type": "TransportConfig | null", "description": "传输配置（通信协议等）" },
        { "name": "tls", "type": "TlsConfig | null", "description": "TLS 配置" }
      ]
    },
    "AuthConfig": {
      "description": "鉴权配置",
      "fields": [
        { "name": "method", "type": "String | null", "description": "鉴权方式（如 token）" },
        { "name": "token", "type": "String | null", "description": "鉴权密钥" }
      ]
    },
    "TransportConfig": {
      "description": "传输配置（对应 [transport]）",
      "fields": [
        { "name": "protocol", "type": "String | null", "description": "通信协议（tcp/kcp/websocket/quic）" },
        { "name": "tcpMux", "type": "bool | null", "description": "TCP 多路复用" }
      ]
    },
    "TlsConfig": {
      "description": "TLS 配置（对应 [tls]）",
      "fields": [
        { "name": "enable", "type": "bool | null", "description": "是否启用 TLS" }
      ]
    },
    "ProxyItem": {
      "description": "代理配置（对应 [[proxies]]），字段名与 TOML 完全一致",
      "fields": [
        { "name": "name", "type": "String", "description": "代理名称" },
        { "name": "desc", "type": "String | null", "description": "代理描述" },
        { "name": "enabled", "type": "bool", "description": "是否启用（默认 true）" },
        { "name": "type", "type": "String", "description": "代理类型（http/https/tcp/udp 等）" },
        { "name": "localIP", "type": "String | null", "description": "本地 IP" },
        { "name": "localPort", "type": "u16", "description": "本地端口" },
        { "name": "remotePort", "type": "u16 | null", "description": "远程端口（tcp/udp 代理必填）" },
        { "name": "customDomains", "type": "Vec<String> | null", "description": "绑定域名列表" },
        { "name": "locations", "type": "Vec<String> | null", "description": "路径列表" }
      ]
    },
    "FrpcVersionInfo": {
      "description": "frpc 内核版本信息",
      "fields": [
        { "name": "current_version", "type": "String", "description": "当前安装的 frpc 版本，如 '0.69.1'，未安装则为 '0'" },
        { "name": "latest_version", "type": "String", "description": "GitHub 最新 release 版本，如 '0.69.1'，获取失败则为空字符串" },
        { "name": "can_upgrade", "type": "bool", "description": "是否有可升级的新版本" },
        { "name": "platform", "type": "String", "description": "当前操作系统，如 'windows'/'darwin'/'linux'" },
        { "name": "arch", "type": "String", "description": "当前 CPU 架构，如 'amd64'/'arm64'" }
      ]
    }
  }
}
