{
  "version": "V10",
  "lastUpdated": "2026-06-28",
  "commands": [
    {
      "name": "list_servers",
      "description": "获取所有服务器配置列表（扫描 conf/frpc.*.toml）",
      "parameters": [],
      "returns": {
        "type": "Result<Vec<ServerInfo>, String>",
        "success": "按 sort 排序的服务器数组",
        "error": "错误信息字符串"
      }
    },
    {
      "name": "get_server",
      "description": "获取单个服务器配置",
      "parameters": [
        { "name": "id", "type": "String", "description": "服务器 ID（文件名中的标识）" }
      ],
      "returns": {
        "type": "Result<ServerInfo, String>",
        "success": "服务器配置对象",
        "error": "错误信息字符串"
      }
    },
    {
      "name": "create_server",
      "description": "创建新的服务器配置文件 conf/frpc.{id}.toml，id 由后端自动生成（单字母 a..z）",
      "parameters": [
        { "name": "input", "type": "CreateServerInput", "description": "服务器配置（不含 id）" }
      ],
      "returns": {
        "type": "Result<String, String>",
        "success": "自动生成的服务器 ID（单字母）",
        "error": "错误信息字符串"
      }
    },
    {
      "name": "update_server",
      "description": "更新服务器配置（保留 log/proxies）",
      "parameters": [
        { "name": "server", "type": "ServerInfo", "description": "新的服务器配置" }
      ],
      "returns": {
        "type": "Result<(), String>",
        "success": "空",
        "error": "错误信息字符串"
      }
    },
    {
      "name": "delete_server",
      "description": "删除服务器配置文件",
      "parameters": [
        { "name": "id", "type": "String", "description": "服务器 ID" }
      ],
      "returns": {
        "type": "Result<(), String>",
        "success": "空",
        "error": "错误信息字符串"
      }
    },
    {
      "name": "reorder_servers",
      "description": "批量更新服务器排序（按数组顺序分配 sort=1..N）",
      "parameters": [
        { "name": "ids", "type": "Vec<String>", "description": "排序后的服务器 ID 列表" }
      ],
      "returns": {
        "type": "Result<(), String>",
        "success": "空",
        "error": "错误信息字符串"
      }
    },
    {
      "name": "list_proxies",
      "description": "获取指定服务器的所有代理列表",
      "parameters": [
        { "name": "server_id", "type": "String", "description": "服务器 ID" }
      ],
      "returns": {
        "type": "Result<Vec<ProxyItem>, String>",
        "success": "代理配置数组",
        "error": "错误信息字符串"
      }
    },
    {
      "name": "create_proxy",
      "description": "在指定服务器中添加代理",
      "parameters": [
        { "name": "server_id", "type": "String", "description": "服务器 ID" },
        { "name": "proxy", "type": "ProxyItem", "description": "代理配置" }
      ],
      "returns": {
        "type": "Result<(), String>",
        "success": "空",
        "error": "错误信息字符串"
      }
    },
    {
      "name": "update_proxy",
      "description": "更新指定服务器中的代理（支持重命名，old_name 匹配原名）",
      "parameters": [
        { "name": "server_id", "type": "String", "description": "服务器 ID" },
        { "name": "old_name", "type": "String", "description": "代理原名" },
        { "name": "proxy", "type": "ProxyItem", "description": "新的代理配置" }
      ],
      "returns": {
        "type": "Result<(), String>",
        "success": "空",
        "error": "错误信息字符串"
      }
    },
    {
      "name": "delete_proxy",
      "description": "删除指定服务器中的代理",
      "parameters": [
        { "name": "server_id", "type": "String", "description": "服务器 ID" },
        { "name": "name", "type": "String", "description": "代理名称" }
      ],
      "returns": {
        "type": "Result<(), String>",
        "success": "空",
        "error": "错误信息字符串"
      }
    },
    {
      "name": "reorder_proxies",
      "description": "重新排序指定服务器中的代理（按数组顺序重排 [[proxies]]）",
      "parameters": [
        { "name": "server_id", "type": "String", "description": "服务器 ID" },
        { "name": "names", "type": "Vec<String>", "description": "排序后的代理名称列表" }
      ],
      "returns": {
        "type": "Result<(), String>",
        "success": "空",
        "error": "错误信息字符串"
      }
    },
    {
      "name": "get_frpc_version",
      "description": "获取 frpc 内核版本信息（当前版本/最新版本/可升级状态/平台/架构）。最新版本从 scoop 仓库获取（GitHub raw 优先，gitee 镜像回退）",
      "parameters": [],
      "returns": {
        "type": "Result<FrpcVersionInfo, String>",
        "success": "版本信息对象",
        "error": "错误信息字符串"
      }
    },
    {
      "name": "upgrade_frpc",
      "description": "下载并升级/安装 frpc 内核（从 GitHub Releases 下载对应平台架构的 zip，解压并替换可执行文件）",
      "parameters": [
        { "name": "version", "type": "String", "description": "要下载的版本号，如 '0.69.1'（不含 v 前缀）" }
      ],
      "returns": {
        "type": "Result<(), String>",
        "success": "空（成功替换）",
        "error": "错误信息字符串（下载失败/解压失败/未找到 frpc 可执行文件/替换失败）"
      }
    },
    {
      "name": "export_backup",
      "description": "导出配置备份（弹出保存对话框，将 conf 目录所有 .toml 文件打包为 zip）",
      "parameters": [],
      "returns": {
        "type": "Result<String, String>",
        "success": "保存的文件路径（如 'C:\\Users\\xxx\\frpc-260627120000.zip'）",
        "error": "错误信息字符串（用户取消/创建文件失败/读取目录失败等）"
      }
    },
    {
      "name": "restore_backup",
      "description": "导入配置备份（弹出打开对话框，选择 zip 文件，解压所有 .toml 到 conf 目录，覆盖同名文件）",
      "parameters": [],
      "returns": {
        "type": "Result<(), String>",
        "success": "空（成功恢复）",
        "error": "错误信息字符串（用户取消/打开文件失败/解压失败等）"
      }
    },
    {
      "name": "get_config",
      "description": "获取应用配置（读取 conf/config.toml，不存在则返回默认值）",
      "parameters": [],
      "returns": {
        "type": "Result<AppConfig, String>",
        "success": "应用配置对象",
        "error": "错误信息字符串"
      }
    },
    {
      "name": "save_config",
      "description": "保存应用配置到 conf/config.toml",
      "parameters": [
        { "name": "config", "type": "AppConfig", "description": "应用配置对象" }
      ],
      "returns": {
        "type": "Result<(), String>",
        "success": "空",
        "error": "错误信息字符串"
      }
    },
    {
      "name": "start_frpc",
      "description": "启动指定服务器的 frpc 进程",
      "parameters": [
        { "name": "server_id", "type": "String", "description": "服务器 ID" }
      ],
      "returns": {
        "type": "Result<(), String>",
        "success": "空",
        "error": "错误信息字符串"
      }
    },
    {
      "name": "stop_frpc",
      "description": "停止指定服务器的 frpc 进程",
      "parameters": [
        { "name": "server_id", "type": "String", "description": "服务器 ID" }
      ],
      "returns": {
        "type": "Result<(), String>",
        "success": "空",
        "error": "错误信息字符串"
      }
    },
    {
      "name": "start_all_frpc",
      "description": "一键启动所有激活服务器的 frpc 进程",
      "parameters": [],
      "returns": {
        "type": "Result<(), String>",
        "success": "空",
        "error": "错误信息字符串"
      }
    },
    {
      "name": "stop_all_frpc",
      "description": "一键停止所有运行中的 frpc 进程",
      "parameters": [],
      "returns": {
        "type": "Result<(), String>",
        "success": "空",
        "error": "错误信息字符串"
      }
    },
    {
      "name": "get_all_frpc_status",
      "description": "获取所有服务器的 frpc 运行状态（同步用，前端轮询或启动后调一次）",
      "parameters": [],
      "returns": {
        "type": "Result<Vec<FrpcRunningStatus>, String>",
        "success": "所有服务器的运行状态数组",
        "error": "错误信息字符串"
      }
    }
  ],
  "dataStructures": {
    "ServerInfo": {
      "description": "服务器配置（对应 conf/frpc.{id}.toml）",
      "fields": [
        { "name": "id", "type": "String", "description": "服务器唯一标识（文件名中的 ID，如 frpc.w.toml → 'w'）" },
        { "name": "title", "type": "String", "description": "服务器标题" },
        { "name": "enable", "type": "bool", "description": "是否启用" },
        { "name": "sort", "type": "i32", "description": "排序序号" },
        { "name": "serverAddr", "type": "String", "description": "服务器地址（IP）" },
        { "name": "serverPort", "type": "u16", "description": "服务器端口" },
        { "name": "auth", "type": "AuthConfig | null", "description": "鉴权配置" },
        { "name": "transport", "type": "TransportConfig | null", "description": "传输配置（通信协议等）" },
        { "name": "tls", "type": "TlsConfig | null", "description": "TLS 配置" }
      ]
    },
    "CreateServerInput": {
      "description": "创建服务器时的输入（不含 id，由后端自动生成）",
      "fields": [
        { "name": "title", "type": "String", "description": "服务器标题" },
        { "name": "enable", "type": "bool", "description": "是否启用" },
        { "name": "sort", "type": "i32", "description": "排序序号" },
        { "name": "serverAddr", "type": "String", "description": "服务器地址（IP）" },
        { "name": "serverPort", "type": "u16", "description": "服务器端口" },
        { "name": "auth", "type": "AuthConfig | null", "description": "鉴权配置" },
        { "name": "transport", "type": "TransportConfig | null", "description": "传输配置（通信协议等）" },
        { "name": "tls", "type": "TlsConfig | null", "description": "TLS 配置" }
      ]
    },
    "AuthConfig": {
      "description": "鉴权配置",
      "fields": [
        { "name": "method", "type": "String | null", "description": "鉴权方式（如 token）" },
        { "name": "token", "type": "String | null", "description": "鉴权密钥" }
      ]
    },
    "TransportConfig": {
      "description": "传输配置（对应 [transport]）",
      "fields": [
        { "name": "protocol", "type": "String | null", "description": "通信协议（tcp/kcp/websocket/quic）" },
        { "name": "tcpMux", "type": "bool | null", "description": "TCP 多路复用" }
      ]
    },
    "TlsConfig": {
      "description": "TLS 配置（对应 [tls]）",
      "fields": [
        { "name": "enable", "type": "bool | null", "description": "是否启用 TLS" }
      ]
    },
    "ProxyItem": {
      "description": "代理配置（对应 [[proxies]]），字段名与 TOML 完全一致",
      "fields": [
        { "name": "name", "type": "String", "description": "代理名称" },
        { "name": "desc", "type": "String | null", "description": "代理描述" },
        { "name": "enabled", "type": "bool", "description": "是否启用（默认 true）" },
        { "name": "type", "type": "String", "description": "代理类型（http/https/tcp/udp 等）" },
        { "name": "localIP", "type": "String | null", "description": "本地 IP" },
        { "name": "localPort", "type": "u16", "description": "本地端口" },
        { "name": "remotePort", "type": "u16 | null", "description": "远程端口（tcp/udp 代理必填）" },
        { "name": "customDomains", "type": "Vec<String> | null", "description": "绑定域名列表" },
        { "name": "locations", "type": "Vec<String> | null", "description": "路径列表" }
      ]
    },
    "FrpcVersionInfo": {
      "description": "frpc 内核版本信息",
      "fields": [
        { "name": "current_version", "type": "String", "description": "当前安装的 frpc 版本，如 '0.69.1'，未安装则为 '0'" },
        { "name": "latest_version", "type": "String", "description": "GitHub 最新 release 版本，如 '0.69.1'，获取失败则为空字符串" },
        { "name": "can_upgrade", "type": "bool", "description": "是否有可升级的新版本" },
        { "name": "platform", "type": "String", "description": "当前操作系统，如 'windows'/'darwin'/'linux'" },
        { "name": "arch", "type": "String", "description": "当前 CPU 架构，如 'amd64'/'arm64'" }
      ]
    },
    "AppConfig": {
      "description": "应用配置（对应 conf/config.toml）",
      "fields": [
        { "name": "language", "type": "String", "description": "界面语言，默认 'zh-CN'" },
        { "name": "theme", "type": "String", "description": "主题模式（system/light/dark），默认 'system'" },
        { "name": "autostart", "type": "bool", "description": "开机自启动，默认 false" },
        { "name": "silent_launch", "type": "bool", "description": "静默启动（不显示主窗口），默认 false" },
        { "name": "auto_run", "type": "bool", "description": "自动运行代理，默认 false" },
        { "name": "show_frpc_console", "type": "bool", "description": "显示 frpc 命令行窗口（调试用），默认 false" },
        { "name": "use_github_proxy", "type": "bool", "description": "优先使用代理/镜像访问 GitHub（GitHub 不可用时开启），默认 false" }
      ]
    },
    "FrpcRunningStatus": {
      "description": "frpc 运行状态（每个服务器一个）",
      "fields": [
        { "name": "server_id", "type": "String", "description": "服务器 ID" },
        { "name": "status", "type": "String", "description": "运行状态：'running'/'stopped'/'error'" },
        { "name": "pid", "type": "u32 | null", "description": "进程 PID，未运行时为 null" },
        { "name": "error_message", "type": "String | null", "description": "错误信息（status=error 时）" }
      ]
    }
  },
  "events": [
    {
      "name": "frpc-status-changed",
      "payload": {
        "description": "frpc 进程状态变化时推送",
        "fields": [
          { "name": "server_id", "type": "String", "description": "服务器 ID" },
          { "name": "old_status", "type": "String", "description": "旧状态" },
          { "name": "new_status", "type": "String", "description": "新状态" },
          { "name": "pid", "type": "u32 | null", "description": "进程 PID" },
          { "name": "error_message", "type": "String | null", "description": "错误信息。已知错误映射为简洁英文摘要（见 errorCodes），带 {placeholder} 的已替换为实际值。未知错误保底原始行（截断 120 字符）。正常停止或无输出时为 null。" }
        ]
      },
      "errorCodes": {
        "description": "summarize_frpc_error() 输出的已知错误摘要。带 {placeholder} 的表示动态提取变量。前端可据此做 i18n 翻译，翻译时保留 {placeholder} 原样替换。",
        "values": [
          "Login to server failed",
          "Config parse error: {detail}",
          "Unknown config field \"{name}\"",
          "Proxy name \"{name}\" already in use",
          "Token mismatch",
          "TLS certificate verification failed: {reason}",
          "TLS error: {detail}",
          "Connection refused",
          "Connection reset",
          "Network unreachable",
          "Connection timeout",
          "Reconnect timeout",
          "Port {port} already in use",
          "Port {port} unavailable",
          "Health check failed: {detail}",
          "Control channel closed",
          "Permission denied",
          "Connection closed unexpectedly"
        ]
      }
    }
  ]
}
